---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const base = import.meta.env.BASE_URL;

const categoryColors: Record<string, string> = {
  music:    'text-cn-purple-l bg-cn-purple/10',
  or:       'text-cn-teal    bg-cn-teal/10',
  food:     'text-cn-gold-l  bg-cn-gold/10',
  personal: 'text-cn-muted   bg-cn-surface-2',
  culture:  'text-pink-400   bg-pink-400/10',
};

function categoryClass(cat?: string) {
  return cat ? (categoryColors[cat] ?? categoryColors.personal) : categoryColors.personal;
}
---

<BaseLayout
  title="Writing"
  description="Notes on operations research, music, culture, and whatever I can't stop thinking about."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-16">

    <header class="mb-14">
      <p class="font-mono text-cn-gold text-sm mb-3">/ writing</p>
      <h1 class="font-display font-bold text-4xl sm:text-5xl text-cn-text mb-4">Writing</h1>
      <p class="text-cn-muted text-lg max-w-xl">
        Notes, essays, and miscellany. Topics drift across operations research, music, food, culture,
        and anything else I can't stop thinking about.
      </p>
    </header>

    <div class="space-y-6">
      {posts.map((post) => (
        <a
          href={`${base}blog/${post.slug}`}
          class="group block bg-cn-surface border border-cn-border rounded-xl p-6 hover:border-cn-gold/40 hover:bg-cn-surface-2 transition-all"
        >
          <div class="flex items-center gap-3 mb-3">
            {post.data.category && (
              <span class:list={['text-xs font-mono rounded px-2 py-0.5', categoryClass(post.data.category)]}>
                {post.data.category}
              </span>
            )}
            <time class="text-xs text-cn-muted font-mono" datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
          <h2 class="font-display font-semibold text-cn-text text-xl mb-2 group-hover:text-cn-gold-l transition-colors">
            {post.data.title}
          </h2>
          <p class="text-cn-muted text-sm leading-relaxed">{post.data.description}</p>
          {post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {post.data.tags.map((tag) => (
                <span class="text-xs font-mono text-cn-muted bg-cn-surface border border-cn-border rounded px-2 py-0.5">
                  #{tag}
                </span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>

  </div>
</BaseLayout>
