---
import BaseLayout from '../layouts/BaseLayout.astro';

// TODO: Replace with your real tattoos
// Add image paths to /public/ink/ and reference them here
const tattoos = [
  {
    id:      1,
    title:   'Tattoo Title',
    artist:  'Artist Name',
    studio:  'Studio Name',
    city:    'City, State',
    date:    'Month Year',
    story:   'Add a brief story or meaning behind this piece here. This is your space to share what it means to you.',
    image:   null, // e.g. '/ink/tattoo-01.jpg'
    tags:    ['blackwork', 'geometric'],
  },
];
---

<BaseLayout
  title="Ink"
  description="A living record of my tattoo journey — the art, the stories, and the people behind them."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-16">

    <header class="mb-14">
      <p class="font-mono text-cn-purple text-sm mb-3">/ ink</p>
      <h1 class="font-display font-bold text-4xl sm:text-5xl text-cn-text mb-4">Ink</h1>
      <p class="text-cn-muted text-lg max-w-xl">
        Each piece tells a story. This is a living record of my tattoo journey — the art, the artists,
        and why they're permanent.
      </p>
    </header>

    <div class="space-y-10">
      {tattoos.map(({ id, title, artist, studio, city, date, story, image, tags }) => (
        <article class="bg-cn-surface border border-cn-border rounded-xl overflow-hidden">
          {image ? (
            <img
              src={image}
              alt={title}
              class="w-full h-64 object-cover"
              loading="lazy"
            />
          ) : (
            <div class="w-full h-48 bg-cn-surface-2 border-b border-cn-border flex items-center justify-center text-cn-muted">
              <div class="text-center">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="mx-auto mb-2 opacity-40">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <polyline points="21 15 16 10 5 21"/>
                </svg>
                <p class="text-xs font-mono opacity-40">photo coming soon</p>
              </div>
            </div>
          )}
          <div class="p-6">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-4">
              <div>
                <h2 class="font-display font-semibold text-cn-text text-xl mb-1">{title}</h2>
                <p class="text-cn-purple-l text-sm">
                  by {artist} · {studio}, {city}
                </p>
              </div>
              <span class="font-mono text-cn-muted text-sm flex-shrink-0">{date}</span>
            </div>
            <p class="text-cn-muted leading-relaxed text-sm mb-4">{story}</p>
            {tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <span class="text-xs font-mono text-cn-muted bg-cn-surface-2 border border-cn-border rounded px-2 py-0.5">
                    #{tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        </article>
      ))}
    </div>

  </div>
</BaseLayout>
