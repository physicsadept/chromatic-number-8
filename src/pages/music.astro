---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Music"
  description="Original music, performances, and what's been living in my ears."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-16">

    <header class="mb-14">
      <p class="font-mono text-cn-purple text-sm mb-3">/ music</p>
      <h1 class="font-display font-bold text-4xl sm:text-5xl text-cn-text mb-4">Music</h1>
      <p class="text-cn-muted text-lg max-w-xl">
        Original work, performances, and the records that have shaped how I hear the world.
      </p>
    </header>

    <!-- Original Music -->
    <section class="mb-16">
      <h2 class="font-display font-semibold text-xl text-cn-text mb-6 pb-3 border-b border-cn-border">
        Original Work
      </h2>
      <!-- TODO: Add tracks/albums. Embed SoundCloud, Bandcamp, YouTube, etc. -->
      <div class="bg-cn-surface border border-cn-border rounded-xl p-8 text-center text-cn-muted">
        <p class="font-mono text-sm">// coming soon</p>
        <p class="text-sm mt-2">Tracks and recordings will live here.</p>
      </div>
    </section>

    <!-- Currently Listening -->
    <section class="mb-16">
      <h2 class="font-display font-semibold text-xl text-cn-text mb-6 pb-3 border-b border-cn-border">
        Currently Listening
      </h2>
      <!-- TODO: Update with what you're into now. Can be a simple list or embed last.fm/spotify widgets -->
      <ul class="space-y-3">
        {[
          { artist: 'Artist Name',   album: 'Album Title',        year: '2024' },
          { artist: 'Artist Name',   album: 'Album Title',        year: '2023' },
          { artist: 'Artist Name',   album: 'Album Title',        year: '2024' },
        ].map(({ artist, album, year }) => (
          <li class="flex items-center gap-4 bg-cn-surface border border-cn-border rounded-lg px-5 py-4 hover:border-cn-purple/40 transition-colors">
            <div class="w-10 h-10 rounded bg-cn-surface-2 border border-cn-border flex-shrink-0 flex items-center justify-center text-cn-muted">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/>
              </svg>
            </div>
            <div class="min-w-0">
              <p class="text-cn-text font-medium text-sm truncate">{album}</p>
              <p class="text-cn-muted text-xs">{artist} · {year}</p>
            </div>
          </li>
        ))}
      </ul>
    </section>

  </div>
</BaseLayout>
